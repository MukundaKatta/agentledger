# Copy to `.env` for local dev. On Vercel, set these as Environment Variables.

# AWS region your DynamoDB table lives in
AWS_REGION=us-east-1

# AWS credentials for an IAM user limited to the AgentLedger table (see README → iam-policy.json).
# Locally you can instead rely on `aws configure` / SSO and omit these two.
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key

# DynamoDB table name (created by `npm run create-table`)
DDB_TABLE=AgentLedger

# Shared secret required on POST /api/ingest. Use a long random string.
# Set the SAME value in whatever agent reports runs (see examples/report.py).
INGEST_TOKEN=change-me-to-a-long-random-string
